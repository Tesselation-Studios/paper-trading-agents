{
  "agent": "stonks",
  "account": "stonks",
  "phase": "mvp-1",
  "strategy_version": "stonks.strat:v1.3.1",

  "tick": {
    "interval_seconds": 300,
    "active_hours": "09:30-16:00",
    "timezone": "America/New_York"
  },

  "universe": {
    "min_price": 1.0,
    "max_price": 50.0,
    "cap_class": "small-mid"
  },

  "risk": {
    "stop_loss_pct": -10.0,
    "trailing_stop_pct": 5.0,
    "profit_target_pct": 12.0,
    "profit_target_is_guide": true,
    "max_position_pct": 6.0,
    "max_positions": 25,
    "conviction_floor": 0.50,
    "max_portfolio_risk_pct": 8.0,
    "_trailing_stop_source": "2026-07-20 guardrail engine — ratchets up from peak price since entry, mechanically enforced in scripts/guardrails.py check-stops, not LLM-judgment"
  },

  "exit_rules": {
    "rsi_exhaustion_hard_exit": 75.0,
    "_source": "kairos — absolute override, not negotiated by MACD"
  },

  "entry_rules": {
    "earnings_blackout_days": 3,
    "triple_confirmation_required": true,
    "triple_confirmation_weights": {"rsi_gt_55_rising": 0.33, "macd_gt_signal_and_positive": 0.33, "price_gt_ma20_ma50": 0.33},
    "sector_etfs_for_veto": ["XLK", "SMH", "XLF", "XLV", "XLC", "XLY"],
    "_source": "kairos — 2-of-3 confirmation = half-size probe, 3-of-3 + catalyst + sector tailwind = full size"
  },

  "regime_sizing": {
    "vix_lt_17_size_mult": 1.0,
    "vix_20_30_size_mult": 0.5,
    "vix_gt_30_size_mult": 0.25,
    "vix_gt_35_size_mult": 0.0,
    "_source": "kairos VIX tiers, absorbs aldridge's widen-stops-in-chop pattern as one mechanism"
  },

  "risk_guards": {
    "max_positions_per_sector": 2,
    "order_count_audit_threshold_daily": 10,
    "max_holding_days": 5,
    "_source": "kairos — concentration/rogue-trading guards + time-stop backstop"
  },

  "trim": {
    "profit_target_trim_pct": 0.25,
    "_source": "aldridge — partial profit-taking instead of binary exit"
  },

  "quality_gate": {
    "max_debt_to_equity": 2.0,
    "min_fcf_yield_pct": 4.0,
    "_source": "aldridge — cheap balance-sheet sanity check, not a full value model"
  },

  "watchlist": {
    "path": "strategies/watchlist.md",
    "idle_ticks_before_drop": 24,
    "max_size": 30
  },

  "synthesis": {
    "lookback_n_entries": 10
  },

  "alpaca": {
    "base_url": "https://paper-api.alpaca.markets",
    "time_in_force": "day",
    "order_type": "market"
  },

  "strategy_files": [
    "strategy.md",
    "strategies/active.md",
    "strategies/watchlist.md"
  ],

  "journal": {
    "path": "journal/",
    "format": "YYYY-MM-DD.md",
    "git_commit": true
  },

  "executor": {
    "script": "scripts/executor.py",
    "python": "python3"
  },

  "not_yet_built": [
    "ml_technical_scanning",
    "news_source_aggregation",
    "trading_terminal_mcp"
  ],

  "guardrail_gates": {
    "cash": true,
    "position_size": true,
    "max_positions": true,
    "sector_concentration": true,
    "hours": true,
    "conviction": true,
    "hard_stop": true,
    "trailing_stop": true,
    "bankroll": true,
    "_note": "2026-07-20 guardrail engine — flip any gate to false to disable it without touching code. scripts/executor.py reads this every run. bankroll gate added 2026-07-21: wires bankroll.py's win/loss-adaptive ceiling into real position sizing (see bankroll.md for current ceiling)."
  }
}
