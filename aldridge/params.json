{
  "agent": "aldridge",
  "account": "aldridge",
  "phase": 1,
  "strategy_version": "ald.strat:v1.0",

  "tick": {
    "interval_seconds": 300,
    "active_hours": "09:30-16:00",
    "timezone": "America/New_York"
  },

  "risk": {
    "stop_loss_pct": -5.0,
    "profit_target_pct": 10.0,
    "max_position_pct": 20.0,
    "max_positions": 20,
    "conviction_floor": 0.60,
    "max_portfolio_risk_pct": 5.0
  },

  "alpaca": {
    "base_url": "https://paper-api.alpaca.markets",
    "time_in_force": "day",
    "order_type": "market"
  },

  "strategy_files": [
    "strategy.md",
    "strategies/active.md"
  ],

  "journal": {
    "path": "journal/",
    "format": "YYYY-MM-DD.md",
    "git_commit": true
  },

  "executor": {
    "script": "scripts/executor.py",
    "python": "python3"
  }
}